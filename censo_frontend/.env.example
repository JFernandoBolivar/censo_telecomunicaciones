# Django backend API server (con slash al final)
DJANGO_API_SERVER=http://localhost:8000/api/

# NextAuth.js secret (generar con: openssl rand -base64 32)
NEXTAUTH_SECRET=your-secret-here

# URL del frontend para NextAuth
NEXTAUTH_URL=http://localhost:3000

# Better Auth secret (generar con: openssl rand -base64 32)
BETTER_AUTH_SECRET=your-secret-here
